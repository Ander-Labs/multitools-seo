  HmacTool, RsaTool, Bip39Tool, BcryptTool, OtpTool, CipherTool, JwtTool, UserAgentTool,
  HttpStatusTool, MetaTagTool, SafeLinkTool,
  YamlJsonTool, JsonYamlTool, YamlTomlTool, JsonTomlTool, TomlJsonTool, TomlYamlTool, XmlJsonTool, JsonXmlTool, MarkdownHtmlTool, NatoTool, BinaryTool, UnicodeTool, HtmlEntitiesTool, UrlParserTool, BasicAuthTool, OgMetaTool, KeycodeTool, DeviceTool, LoremTool, TextStatsTool, ListTool, NumeronymTool, ObfuscateTool, TextDiffTool, JsonDiffTool, RegexTool, AsciiDrawerTool, MathTool, PercentageTool, EtaTool, TemperatureTool, ChronometerTool, BenchmarkTool, DateTool, BaseConvTool, RomanTool, TokenTool, UlidTool, RandomPortTool, ChmodTool, MimeTool, DockerTool, JsonCsvTool, JsonMinifyTool, XmlFmtTool, SqlFmtTool, YamlFmtTool, Ipv4CalcTool, Ipv4ConvTool, Ipv4RangeTool, MacGenTool, MacLookupTool, Ipv6UlaTool, QrTool, WifiQrTool, SvgPlaceholderTool, EmailNormalizerTool, PhoneTool, IbanTool, PdfSigTool, GitMemoTool, RegexMemoTool, EmojiTool, CameraTool, Base64FileTool,
};

export async function getStaticPaths() {
  const esTools = await getCollection('tools');
  const enTools = await getCollection('toolsEn');
  const paths: any[] = [];
  for (const locale of ['es', 'en'] as const) {
    const set = locale === 'es' ? esTools : enTools;
    for (const t of set) {
      paths.push({
        params: { locale, slug: t.data.slug },
        props: { tool: t.data, locale },
      });
    }
  }
  return paths;
}

const { tool, locale } = Astro.props;
const ToolComponent = componentMap[tool.component] ?? Base64Tool;
const activeCategory = locale === 'en' ? tool.category : tool.categoria;
---
<ToolLayout h1={tool.h1} texto_seo={tool.texto_seo} slug={tool.slug} locale={locale} activeCategory={activeCategory}>
  <ToolComponent slot="tool" />
</ToolLayout>
