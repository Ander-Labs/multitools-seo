---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import Sidebar from '../../components/Sidebar.astro';

export async function getStaticPaths() {
  const esTools = await getCollection('tools');
  const enTools = await getCollection('toolsEn');
  return [
    {
      params: { locale: 'es' },
      props: {
        locale: 'es' as const,
        tools: esTools.map((t) => ({ slug: t.data.slug, h1: t.data.h1, categoria: t.data.categoria })),
      },
    },
    {
      params: { locale: 'en' },
      props: {
        locale: 'en' as const,
        tools: enTools.map((t) => ({ slug: t.data.slug, h1: t.data.h1, categoria: t.data.category })),
      },
    },
  ];
}

const { locale, tools } = Astro.props;

// Group tools by category for the responsive home grid.
const groups = new Map<string, { slug: string; h1: string }[]>();
for (const t of tools as any[]) {
  const key = t.categoria as string;
  if (!groups.has(key)) groups.set(key, []);
  groups.get(key)!.push({ slug: t.slug, h1: t.h1 });
}
const categories = [...groups.entries()].sort((a, b) => a[0].localeCompare(b[0]));

const title = locale === 'en' ? 'Free Developer Tools' : 'Herramientas gratuitas para desarrolladores';
const sub = locale === 'en'
  ? '100% processed in your browser. No server uploads — private and fast.'
  : 'Procesado 100% en tu navegador. Sin envíos a servidor, privado y rápido.';
const toolHref = (slug: string) => `/${locale}/${slug}`;
---

<Layout titulo_seo={title} locale={locale}>
  <div class="flex min-h-screen">
    <Sidebar locale={locale} />

    <main class="flex-1 min-w-0">
      <div class="px-4 lg:px-8 py-6 lg:py-8">
        <h1 class="text-2xl lg:text-[32px] font-bold text-white tracking-tight leading-tight mb-3">{title}</h1>
        <p class="text-zinc-400 text-sm lg:text-base leading-relaxed max-w-xl mb-8">{sub}</p>

        <div class="space-y-10">
          {categories.map(([cat, items]) => (
            <section>
              <div class="flex items-center gap-3 mb-4">
                <h2 class="text-lg font-semibold text-white">{cat}</h2>
                <span class="text-xs text-zinc-500 bg-surface-2 border border-zinc-800 rounded-full px-2 py-0.5">
                  {items.length}
                </span>
              </div>
              <div class="grid grid-cols-1 sm:grid-cols-2 xl:grid-cols-3 gap-3">
                {items.map((t) => (
                  <a
                    href={toolHref(t.slug)}
                    class="group bg-surface-2 border border-zinc-800 hover:border-accent-500/50 hover:bg-surface-3 rounded-lg px-4 py-3 text-sm font-medium text-zinc-300 hover:text-white transition-colors flex items-center justify-between gap-2"
                  >
                    <span class="truncate">{t.h1}</span>
                    <svg class="w-4 h-4 text-zinc-600 group-hover:text-accent-400 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
                    </svg>
                  </a>
                ))}
              </div>
            </section>
          ))}
        </div>
      </div>
    </main>
  </div>
</Layout>
