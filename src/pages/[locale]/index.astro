---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import Sidebar from '../../components/Sidebar.astro';

export async function getStaticPaths() {
  const esTools = await getCollection('tools');
  const enTools = await getCollection('toolsEn');
  return [
    { params: { locale: 'es' }, props: { locale: 'es' as const, tools: esTools.map(t => ({ slug: t.data.slug, h1: t.data.h1, categoria: t.data.categoria })) } },
    { params: { locale: 'en' }, props: { locale: 'en' as const, tools: enTools.map(t => ({ slug: t.data.slug, h1: t.data.h1, categoria: t.data.category })) } },
  ];
}

const { locale, tools } = Astro.props;
const title = locale === 'en' ? 'Free Developer Tools' : 'Herramientas gratuitas para desarrolladores';
const sub = locale === 'en'
  ? '100% processed in your browser. No server uploads — private and fast.'
  : 'Procesado 100% en tu navegador. Sin envíos a servidor, privado y rápido.';
---
<Layout titulo_seo={title} locale={locale}>
  <div class="home-layout">
    <Sidebar locale={locale} />
    <div class="home-content">
      <h1>{title}</h1>
      <p class="sub">{sub}</p>
      <ul class="tool-list">
        {tools.map((t: any) => (
          <li><a href={`/${locale}/${t.slug}`}>{t.h1}</a></li>
        ))}
      </ul>
    </div>
  </div>
</Layout>

<style>
  .home-layout { display: flex; gap: 32px; align-items: flex-start; }
  .home-content { flex: 1; min-width: 0; }
  .sub { color: var(--muted); }
  .tool-list { list-style: none; padding: 0; display: grid; gap: 12px; }
  .tool-list a { display: block; background: var(--surface); border: 1px solid var(--border); border-radius: var(--radius); padding: 16px; color: var(--text); font-weight: 600; }
  .tool-list a:hover { border-color: var(--accent); }
  @media (max-width: 720px) {
    .home-layout { flex-direction: column; gap: 20px; }
  }
</style>
