---
const { } = Astro.props;
---
<div class="tool-box" id="box-MacGenTool">
  <label>Cantidad
    <input id="n" type="number" value="1" min="1" max="50" />
  </label>
  <label><input id="upper" type="checkbox" checked /> Mayúsculas</label>
  <button id="run">Generar MAC</button>
  <label style="margin-top:12px; display:block;">Resultado
    <textarea id="out" rows="4" readonly></textarea>
  </label>
</div>
<script>
const box = document.currentScript?.parentElement || document.getElementById('box-MacGenTool');
if (box) {
  const n = box.querySelector('#n'); const upper = box.querySelector('#upper'); const out = box.querySelector('#out'); const btn = box.querySelector('#run');
  const hex = c => { const h = c.toString(16).padStart(2,'0'); return upper.checked ? h.toUpperCase() : h; };
  btn?.addEventListener('click', () => {
    const count = Math.max(1, parseInt(n.value)||1); const arr = new Uint8Array(count*6); crypto.getRandomValues(arr);
    const ids = []; for (let i=0;i<count;i++){ const o=i*6; ids.push([o,o+1,o+2,o+3,o+4,o+5].map(j=>hex(arr[j])).join(':')); }
    out.value = ids.join('\n');
  });
}
</script>
