---
const { } = Astro.props;
---
<div class="tool-box" id="box-HashTool">
  <label>Texto a hashear
    <textarea id="input" rows="6" placeholder="Escribe tu texto..."></textarea>
  </label>
  <button id="run">Generar SHA-256</button>
  <label style="margin-top:12px; display:block;">Hash (hex)
    <textarea id="output" rows="4" readonly></textarea>
  </label>
</div>

<script>
  const box = document.currentScript?.parentElement || document.getElementById('box-HashTool');
  if (box) {
    const input = box.querySelector('#input') as HTMLTextAreaElement;
    const output = box.querySelector('#output') as HTMLTextAreaElement;
    const btn = box.querySelector('#run') as HTMLButtonElement;
    btn?.addEventListener('click', async () => {
      try {
        const data = new TextEncoder().encode(input.value);
        const buf = await crypto.subtle.digest('SHA-256', data);
        const hex = Array.from(new Uint8Array(buf)).map(b => b.toString(16).padStart(2, '0')).join('');
        output.value = hex;
      } catch (e) {
        output.value = 'Error al generar hash.';
      }
    });
  }
</script>
