---
const { } = Astro.props;
---
<div class="tool-box" id="box-TomlYamlTool">
  <label>TOML
    <textarea id="input" rows="8" placeholder="[seccion]&#10;clave = &quot;valor&quot;"></textarea>
  </label>
  <button id="run">Convertir a YAML</button>
  <p id="err" style="color:#f87171;margin-top:8px;"></p>
  <label style="margin-top:12px; display:block;">YAML
    <textarea id="output" rows="8" readonly></textarea>
  </label>
</div>
<script>
import TOML from '@iarna/toml'; import YAML from 'yaml';
const box = document.currentScript?.parentElement || document.getElementById('box-TomlYamlTool');
if (box) {
  const input = box.querySelector('#input'); const output = box.querySelector('#output'); const btn = box.querySelector('#run'); const err = box.querySelector('#err');
  btn?.addEventListener('click', () => {
    try { const obj = TOML.parse(input.value); output.value = YAML.stringify(obj); err.textContent=''; }
    catch (e) { err.textContent = 'Error: ' + e.message; output.value=''; }
  });
}
</script>
