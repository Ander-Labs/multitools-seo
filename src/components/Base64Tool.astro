---
const { mode } = Astro.props;
---
<div class="tool-box" id="box-Base64Tool">
  <label>
    {mode === 'encode' ? 'Texto a codificar' : 'Base64 a decodificar'}
    <textarea id="input" rows="6" placeholder={mode === 'encode' ? 'Escribe tu texto...' : 'Pega tu Base64...'}></textarea>
  </label>
  <button id="run">Convertir</button>
  <label style="margin-top:12px; display:block;">
    Resultado
    <textarea id="output" rows="6" readonly></textarea>
  </label>
</div>

<script>
  const box = document.currentScript?.parentElement || document.getElementById('box-Base64Tool');
  if (box) {
    const input = box.querySelector('#input') as HTMLTextAreaElement;
    const output = box.querySelector('#output') as HTMLTextAreaElement;
    const btn = box.querySelector('#run') as HTMLButtonElement;
    const mode = (box.getAttribute('data-mode') || 'encode') as 'encode' | 'decode';
    btn?.addEventListener('click', () => {
      try {
        output.value = mode === 'encode'
          ? btoa(unescape(encodeURIComponent(input.value)))
          : decodeURIComponent(escape(atob(input.value)));
      } catch (e) {
        output.value = 'Error: entrada inválida.';
      }
    });
  }
</script>
