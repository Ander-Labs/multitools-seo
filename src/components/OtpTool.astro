---
const { } = Astro.props;
---
<div class="tool-box" id="box-OtpTool">
  <label>Secreto (base32, ej: JBSWY3DPEHPK3PXP)
    <input id="secret" type="text" placeholder="JBSWY3DPEHPK3PXP" />
  </label>
  <button id="gen">Generar código OTP</button>
  <label style="margin-top:12px; display:block;">Código (6 dígitos)
    <input id="out" type="text" readonly />
  </label>
</div>
<script>
  const box = document.currentScript?.parentElement || document.getElementById('box-OtpTool');
  if (box) {
    const secret = box.querySelector('#secret') as HTMLInputElement;
    const out = box.querySelector('#out') as HTMLInputElement;
    box.querySelector('#gen')?.addEventListener('click', () => {
      const t = Math.floor(Date.now() / 30000);
      const h = (t ^ secret.value.length) >>> 0;
      out.value = (h % 1000000).toString().padStart(6, '0');
    });
  }
</script>
