---
const { } = Astro.props;
---
<div class="tool-box" id="box-BasicAuthTool">
  <label>Usuario
    <input id="user" type="text" placeholder="usuario" />
  </label>
  <label>Contraseña
    <input id="pass" type="password" placeholder="contraseña" />
  </label>
  <button id="run">Generar cabecera</button>
  <label style="margin-top:12px; display:block;">Cabecera
    <textarea id="out" rows="2" readonly></textarea>
  </label>
</div>
<script>
const box = document.currentScript?.parentElement || document.getElementById('box-BasicAuthTool');
if (box) {
  const u = box.querySelector('#user'); const p = box.querySelector('#pass'); const out = box.querySelector('#out'); const btn = box.querySelector('#run');
  btn?.addEventListener('click', () => {
    const creds = u.value + ':' + p.value;
    out.value = 'Authorization: Basic ' + btoa(unescape(encodeURIComponent(creds)));
  });
}
</script>
