---
const { } = Astro.props;
---
<div class="tool-box" id="box-CaseTool">
  <label>Texto
    <textarea id="input" rows="4" placeholder="Escribe texto..."></textarea>
  </label>
  <button id="lower">minúsculas</button>
  <button id="upper">MAYÚSCULAS</button>
  <button id="title">Título</button>
  <label style="margin-top:12px; display:block;">Resultado
    <textarea id="output" rows="4" readonly></textarea>
  </label>
</div>

<script>
  const box = document.currentScript?.parentElement || document.getElementById('box-CaseTool');
  if (box) {
    const input = box.querySelector('#input') as HTMLTextAreaElement;
    const output = box.querySelector('#output') as HTMLTextAreaElement;
    box.querySelector('#lower')?.addEventListener('click', () => output.value = input.value.toLowerCase());
    box.querySelector('#upper')?.addEventListener('click', () => output.value = input.value.toUpperCase());
    box.querySelector('#title')?.addEventListener('click', () => output.value = input.value.replace(/\w\S*/g, w => w.charAt(0).toUpperCase() + w.slice(1).toLowerCase()));
  }
</script>
