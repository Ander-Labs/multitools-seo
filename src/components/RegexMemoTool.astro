---
const { } = Astro.props;
---
<div class="tool-box" id="box-RegexMemoTool">
  <div id="out"></div>
</div>
<script>
const box = document.currentScript?.parentElement || document.getElementById('box-RegexMemoTool');
if (box) {
  const rows = [
    ['.', 'Cualquier carácter excepto salto de línea'],
    ['\d', 'Dígito (0-9)'],
    ['\w', 'Carácter de palabra (a-z, A-Z, 0-9, _)'],
    ['\s', 'Espacio en blanco'],
    ['^ $', 'Inicio y fin de línea'],
    ['* + ?', '0+, 1+, 0 o 1'],
    ['{n,m}', 'Entre n y m repeticiones'],
    ['( )', 'Grupo de captura'],
    ['[ ]', 'Clase de caracteres'],
    ['|', 'Alternativa (o)'],
    ['(?= )', 'Lookahead positivo'],
  ];
  box.querySelector('#out').innerHTML = '<table class="res-table">'+rows.map(([s,d])=>'<tr><th><code>'+s+'</code></th><td>'+d+'</td></tr>').join('')+'</table>';
}
</script>
