---
const { } = Astro.props;
---
<div class="tool-box" id="box-IbanTool">
  <label>IBAN
    <input id="input" type="text" placeholder="ES91 2100 0418 4502 0005 1332" />
  </label>
  <button id="run">Validar</button>
  <p id="err" style="color:#f87171;margin-top:8px;"></p>
  <div id="out" style="margin-top:12px;"></div>
</div>
<script>
import { isValidIBAN, electronicFormatIBAN } from 'ibantools';
const box = document.currentScript?.parentElement || document.getElementById('box-IbanTool');
if (box) {
  const input = box.querySelector('#input'); const out = box.querySelector('#out'); const btn = box.querySelector('#run'); const err = box.querySelector('#err');
  btn?.addEventListener('click', () => {
    if (!isValidIBAN(input.value)) { err.textContent='IBAN inválido'; out.textContent=''; return; }
    const d = electronicFormatIBAN(input.value);
    out.innerHTML = '<table class="res-table"><tr><th>Válido</th><td>Sí</td></tr><tr><th>Electrónico</th><td>'+d+'</td></tr></table>'; err.textContent='';
  });
}
</script>
