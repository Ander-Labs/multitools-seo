---
const { } = Astro.props;
---
<div class="tool-box">
  <label>Texto / URL
    <textarea id="input" rows="4" placeholder="Pega texto o URL..."></textarea>
  </label>
  <button id="enc">Codificar</button>
  <button id="dec">Decodificar</button>
  <label style="margin-top:12px; display:block;">Resultado
    <textarea id="output" rows="4" readonly></textarea>
  </label>
</div>

<script>
  const box = document.currentScript?.parentElement;
  if (box) {
    const input = box.querySelector('#input') as HTMLTextAreaElement;
    const output = box.querySelector('#output') as HTMLTextAreaElement;
    box.querySelector('#enc')?.addEventListener('click', () => { try { output.value = encodeURIComponent(input.value); } catch { output.value = 'Error'; } });
    box.querySelector('#dec')?.addEventListener('click', () => { try { output.value = decodeURIComponent(input.value); } catch { output.value = 'Error: inválido'; } });
  }
</script>
