---
const { } = Astro.props;
---
<div class="tool-box" id="box-YamlJsonTool">
  <label>YAML
    <textarea id="input" rows="8" placeholder="clave: valor&#10;lista:&#10;  - a&#10;  - b"></textarea>
  </label>
  <button id="run">Convertir a JSON</button>
  <p id="err" style="color:#f87171;margin-top:8px;"></p>
  <label style="margin-top:12px; display:block;">JSON
    <textarea id="output" rows="8" readonly></textarea>
  </label>
</div>
<script>
import YAML from 'yaml';
const box = document.currentScript?.parentElement || document.getElementById('box-YamlJsonTool');
if (box) {
  const input = box.querySelector('#input'); const output = box.querySelector('#output'); const btn = box.querySelector('#run'); const err = box.querySelector('#err');
  btn?.addEventListener('click', () => {
    try { const doc = YAML.parse(input.value); output.value = JSON.stringify(doc, null, 2); err.textContent=''; }
    catch (e) { err.textContent = 'Error: ' + e.message; output.value=''; }
  });
}
</script>
