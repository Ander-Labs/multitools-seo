---
const { } = Astro.props;
---
<div class="tool-box" id="box-JsonCsvTool">
  <label>JSON (arreglo de objetos)
    <textarea id="input" rows="6" placeholder='[{"a":1,"b":2}]'></textarea>
  </label>
  <button id="run">Convertir a CSV</button>
  <p id="err" style="color:#f87171;margin-top:8px;"></p>
  <label style="margin-top:12px; display:block;">CSV
    <textarea id="output" rows="6" readonly></textarea>
  </label>
</div>
<script>
const box = document.currentScript?.parentElement || document.getElementById('box-JsonCsvTool');
if (box) {
  const input = box.querySelector('#input'); const output = box.querySelector('#output'); const btn = box.querySelector('#run'); const err = box.querySelector('#err');
  btn?.addEventListener('click', () => {
    try {
      const data = JSON.parse(input.value);
      if (!Array.isArray(data) || !data.length) throw new Error('se espera un arreglo no vacío de objetos');
      const cols = [...new Set(data.flatMap(o => Object.keys(o)))];
      const esc = v => { v = v==null?'':String(v); return /[",\n]/.test(v) ? '"'+v.replace(/"/g,'""')+'"' : v; };
      const rows = [cols.join(',')].concat(data.map(o => cols.map(c => esc(o[c])).join(',')));
      output.value = rows.join('\n'); err.textContent='';
    } catch (e) { err.textContent = 'Error: ' + e.message; }
  });
}
</script>
