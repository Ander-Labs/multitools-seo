---
import { getCollection } from 'astro:content';
// Category sidebar.
// Renders categories statically from the tools catalog (Astro getCollection),
// grouped by the `categoria` (es) / `category` (en) field, with nav-item
// active states for both the active category and the current tool.
interface Props {
  locale: 'es' | 'en';
  activeCategory?: string;
  currentSlug?: string;
}
const { locale, activeCategory, currentSlug } = Astro.props;

const collection = locale === 'en' ? 'toolsEn' : 'tools';
const FIELD = locale === 'en' ? 'category' : 'categoria';
const all = await getCollection(collection as 'tools');

// Group by category field.
const groups = new Map<string, { slug: string; h1: string }[]>();
for (const t of all) {
  const key = (t.data as any)[FIELD] as string;
  if (!groups.has(key)) groups.set(key, []);
  groups.get(key)!.push({ slug: t.data.slug, h1: t.data.h1 });
}
// Stable display order: by category label.
const categories = [...groups.entries()].sort((a, b) => a[0].localeCompare(b[0]));

const homeHref = `/${locale}/`;
const catHref = (cat: string) => `/${locale}/herramientas/${encodeURIComponent(cat)}`;
const toolHref = (slug: string) => `/${locale}/${slug}`;
---

<aside class="hidden lg:block w-[250px] shrink-0 border-r border-zinc-800/50 bg-surface-1/50">
  <div class="sidebar-scroll py-4 px-3">
    <nav id="desktopNav" class="space-y-4">
      <a
        href={homeHref}
        class={`nav-item flex items-center gap-2.5 px-3 py-1.5 rounded-md text-[13px] ${activeCategory ? 'text-zinc-400' : 'active text-accent-300'}`}
      >
        <span class="w-1 h-1 rounded-full bg-accent-500"></span>
        {locale === 'en' ? 'All tools' : 'Todas las herramientas'}
      </a>
      {categories.map(([cat, items], i) => (
        <div class="category-group cat-group">
          <button
            type="button"
            class="category-header"
            onclick="toggleCategory(this)"
            aria-expanded={activeCategory === cat || i === 0 ? 'true' : 'false'}
          >
            <div class="flex items-center gap-2">
              <span class={`w-1.5 h-1.5 rounded-full ${activeCategory === cat ? 'bg-accent-400' : 'bg-zinc-600'}`}></span>
              <span class={`text-xs font-bold uppercase tracking-wider ${activeCategory === cat ? 'text-accent-400' : 'text-zinc-400'}`}>{cat}</span>
            </div>
            <svg class={`w-3.5 h-3.5 text-zinc-600 category-chevron ${activeCategory === cat || i === 0 ? 'rotated' : ''}`} fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
            </svg>
          </button>
          <div class={`category-content mt-1 ml-2 ${activeCategory === cat || i === 0 ? 'open' : ''}`}>
            <div class="space-y-0.5 pl-2 border-l border-zinc-800">
              {items.map((tool) => (
                <a
                  href={toolHref(tool.slug)}
                  data-search={(tool.h1 + ' ' + cat + ' ' + tool.slug).toLowerCase()}
                  class={`nav-item flex items-center gap-2.5 px-3 py-1.5 rounded-md text-[13px] ${currentSlug === tool.slug ? 'active text-accent-300' : 'text-zinc-400'}`}
                >
                  <span class="w-1 h-1 rounded-full bg-zinc-700"></span>
                  {tool.h1}
                </a>
              ))}
            </div>
          </div>
        </div>
      ))}
    </nav>
  </div>
</aside>

<script>
  // Mirror the desktop sidebar into the mobile drawer nav (single source of truth).
  (function () {
    var src = document.getElementById('desktopNav');
    var dst = document.getElementById('mobileNav');
    if (src && dst) {
      // Preserve the leading "All tools" + slot content already in the drawer.
      var first = dst.firstElementChild;
      var anchor = first ? first.nextSibling : null;
      var clone = src.cloneNode(true) as HTMLElement;
      clone.id = 'mobileNavClone';
      while (clone.firstElementChild && clone.firstElementChild.tagName === 'A') {
        clone.removeChild(clone.firstElementChild);
      }
      dst.appendChild(clone);
      // Re-bind close-on-click for the cloned links.
      clone.querySelectorAll('a[href]').forEach(function (a) {
        a.addEventListener('click', function () {
          var drawer = document.getElementById('mobileDrawer');
          if (drawer) { drawer.classList.remove('active'); document.body.style.overflow = ''; }
        });
      });
    }
  })();
</script>
