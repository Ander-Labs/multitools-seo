---
const { } = Astro.props;
---
<div class="tool-box" id="box-Ipv6UlaTool">
  <button id="run">Generar ULA</button>
  <label style="margin-top:12px; display:block;">Resultado
    <textarea id="out" rows="2" readonly></textarea>
  </label>
</div>
<script>
const box = document.currentScript?.parentElement || document.getElementById('box-Ipv6UlaTool');
if (box) {
  const out = box.querySelector('#out'); const btn = box.querySelector('#run');
  const hex = n => n.toString(16).padStart(4,'0');
  btn?.addEventListener('click', () => {
    const g = new Uint16Array(4); crypto.getRandomValues(g);
    const segs = ['fd' + hex(g[0]).slice(0,2)]; for (let i=1;i<4;i++) segs.push(hex(g[i]));
    out.value = segs.join(':') + '::/48';
  });
}
</script>
