---
const { } = Astro.props;
---
<div class="tool-box" id="box-NumeronymTool">
  <label>Palabra
    <input id="input" type="text" placeholder="internationalization" />
  </label>
  <button id="run">Generar numerónimo</button>
  <label style="margin-top:12px; display:block;">Resultado
    <textarea id="output" rows="2" readonly></textarea>
  </label>
</div>
<script>
const box = document.currentScript?.parentElement || document.getElementById('box-NumeronymTool');
if (box) {
  const input = box.querySelector('#input'); const output = box.querySelector('#output'); const btn = box.querySelector('#run');
  btn?.addEventListener('click', () => {
    const w = input.value.trim();
    output.value = (w.length <= 2) ? w : w[0] + (w.length - 2) + w[w.length - 1];
  });
}
</script>
