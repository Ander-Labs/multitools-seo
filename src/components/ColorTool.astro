---
const { } = Astro.props;
---
<div class="tool-box" id="box-ColorTool">
  <label>Color HEX o RGB
    <input id="input" type="text" placeholder="#7dd3fc o rgb(125,211,252)" />
  </label>
  <button id="conv">Convertir</button>
  <p id="output" style="margin-top:12px;color:#9aa3b2;"></p>
</div>

<script>
  const box = document.currentScript?.parentElement || document.getElementById('box-ColorTool');
  if (box) {
    const input = box.querySelector('#input') as HTMLInputElement;
    const out = box.querySelector('#output') as HTMLParagraphElement;
    box.querySelector('#conv')?.addEventListener('click', () => {
      const v = input.value.trim();
      if (v.startsWith('#')) {
        const r = parseInt(v.slice(1, 3), 16), g = parseInt(v.slice(3, 5), 16), b = parseInt(v.slice(5, 7), 16);
        out.textContent = `rgb(${r}, ${g}, ${b})`;
      } else if (v.startsWith('rgb')) {
        const m = v.match(/\d+/g);
        if (m) out.textContent = '#' + m.slice(0, 3).map(n => (+n).toString(16).padStart(2, '0')).join('');
      } else { out.textContent = 'Formato no reconocido.'; }
    });
  }
</script>
