---
const { } = Astro.props;
---
<div class="tool-box" id="box-XmlJsonTool">
  <label>XML
    <textarea id="input" rows="8" placeholder="<raiz><item>valor</item></raiz>"></textarea>
  </label>
  <button id="run">Convertir a JSON</button>
  <p id="err" style="color:#f87171;margin-top:8px;"></p>
  <label style="margin-top:12px; display:block;">JSON
    <textarea id="output" rows="8" readonly></textarea>
  </label>
</div>
<script>
import { XMLParser } from 'fast-xml-parser';
const box = document.currentScript?.parentElement || document.getElementById('box-XmlJsonTool');
if (box) {
  const input = box.querySelector('#input'); const output = box.querySelector('#output'); const btn = box.querySelector('#run'); const err = box.querySelector('#err');
  btn?.addEventListener('click', () => {
    try {
      const parser = new XMLParser({ ignoreAttributes: false, attributeNamePrefix: '@_' });
      const obj = parser.parse(input.value); output.value = JSON.stringify(obj, null, 2); err.textContent='';
    } catch (e) { err.textContent = 'Error: ' + e.message; output.value=''; }
  });
}
</script>
