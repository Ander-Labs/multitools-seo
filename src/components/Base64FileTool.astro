---
const { } = Astro.props;
---
<div class="tool-box" id="box-Base64FileTool">
  <label>Archivo
    <input id="file" type="file" />
  </label>
  <button id="run">Convertir a Base64</button>
  <p id="err" style="color:#f87171;margin-top:8px;"></p>
  <label style="margin-top:12px; display:block;">Resultado (data URI)
    <textarea id="out" rows="6" readonly></textarea>
  </label>
</div>
<script>
const box = document.currentScript?.parentElement || document.getElementById('box-Base64FileTool');
if (box) {
  const file = box.querySelector('#file'); const out = box.querySelector('#out'); const btn = box.querySelector('#run'); const err = box.querySelector('#err');
  btn?.addEventListener('click', () => {
    const f = file.files[0]; if (!f) { err.textContent='Elige un archivo'; return; }
    const fr = new FileReader();
    fr.onload = () => { out.value = fr.result; err.textContent=''; };
    fr.readAsDataURL(f);
  });
}
</script>
