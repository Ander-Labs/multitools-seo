---
const { } = Astro.props;
---
<div class="tool-box" id="box-RandomPortTool">
  <button id="run">Generar puerto</button>
  <label style="margin-top:12px; display:block;">Resultado
    <textarea id="out" rows="1" readonly></textarea>
  </label>
</div>
<script>
const box = document.currentScript?.parentElement || document.getElementById('box-RandomPortTool');
if (box) {
  const out = box.querySelector('#out'); const btn = box.querySelector('#run');
  btn?.addEventListener('click', () => {
    const p = 1024 + Math.floor(Math.random() * (65535 - 1024));
    out.value = String(p);
  });
}
</script>
