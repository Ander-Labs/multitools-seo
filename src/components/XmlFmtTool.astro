---
const { } = Astro.props;
---
<div class="tool-box" id="box-XmlFmtTool">
  <label>XML
    <textarea id="input" rows="6" placeholder="<a><b>1</b></a>"></textarea>
  </label>
  <button id="run">Formatear</button>
  <p id="err" style="color:#f87171;margin-top:8px;"></p>
  <label style="margin-top:12px; display:block;">Resultado
    <textarea id="output" rows="6" readonly></textarea>
  </label>
</div>
<script>
import { XMLBuilder, XMLParser } from 'fast-xml-parser';
const box = document.currentScript?.parentElement || document.getElementById('box-XmlFmtTool');
if (box) {
  const input = box.querySelector('#input'); const output = box.querySelector('#output'); const btn = box.querySelector('#run'); const err = box.querySelector('#err');
  btn?.addEventListener('click', () => {
    try { const obj = new XMLParser({ ignoreAttributes:false, attributeNamePrefix:'@_' }).parse(input.value); output.value = new XMLBuilder({ format:true, indentBy:'  ' }).build(obj); err.textContent=''; }
    catch (e) { err.textContent='Error: '+e.message; }
  });
}
</script>
