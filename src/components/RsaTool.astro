---
const { } = Astro.props;
---
<div class="tool-box">
  <button id="gen">Generar par de claves RSA (2048)</button>
  <label style="margin-top:12px; display:block;">Clave pública
    <textarea id="pub" rows="4" readonly></textarea>
  </label>
  <label style="margin-top:12px; display:block;">Clave privada
    <textarea id="priv" rows="6" readonly></textarea>
  </label>
</div>
<script>
  const box = document.currentScript?.parentElement;
  if (box) {
    const pub = box.querySelector('#pub') as HTMLTextAreaElement;
    const priv = box.querySelector('#priv') as HTMLTextAreaElement;
    box.querySelector('#gen')?.addEventListener('click', async () => {
      const pair = await crypto.subtle.generateKey({ name: 'RSASSA-PKCS1-v1_5', modulusLength: 2048, publicExponent: new Uint8Array([1,0,1]), hash: 'SHA-256' }, true, ['sign','verify']);
      pub.value = await crypto.subtle.exportKey('spki', pair.publicKey).then(b => '-----BEGIN PUBLIC KEY-----\n' + btoa(String.fromCharCode(...new Uint8Array(b))) + '\n-----END PUBLIC KEY-----');
      priv.value = await crypto.subtle.exportKey('pkcs8', pair.privateKey).then(b => '-----BEGIN PRIVATE KEY-----\n' + btoa(String.fromCharCode(...new Uint8Array(b))) + '\n-----END PRIVATE KEY-----');
    });
  }
</script>
