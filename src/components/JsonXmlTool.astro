---
const { } = Astro.props;
---
<div class="tool-box" id="box-JsonXmlTool">
  <label>JSON
    <textarea id="input" rows="8" placeholder='{"raiz":{"item":"valor"}}'></textarea>
  </label>
  <button id="run">Convertir a XML</button>
  <p id="err" style="color:#f87171;margin-top:8px;"></p>
  <label style="margin-top:12px; display:block;">XML
    <textarea id="output" rows="8" readonly></textarea>
  </label>
</div>
<script>
import { XMLBuilder } from 'fast-xml-parser';
const box = document.currentScript?.parentElement || document.getElementById('box-JsonXmlTool');
if (box) {
  const input = box.querySelector('#input'); const output = box.querySelector('#output'); const btn = box.querySelector('#run'); const err = box.querySelector('#err');
  btn?.addEventListener('click', () => {
    try {
      const obj = JSON.parse(input.value);
      const builder = new XMLBuilder({ format: true, indentBy: '  ', ignoreAttributes: false });
      output.value = builder.build(obj); err.textContent='';
    } catch (e) { err.textContent = 'Error: ' + e.message; output.value=''; }
  });
}
</script>
