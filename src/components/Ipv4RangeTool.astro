---
const { } = Astro.props;
---
<div class="tool-box" id="box-Ipv4RangeTool">
  <label>IP inicio
    <input id="a" type="text" placeholder="192.168.1.0" />
  </label>
  <label>IP fin
    <input id="b" type="text" placeholder="192.168.1.255" />
  </label>
  <button id="run">Calcular CIDR</button>
  <p id="err" style="color:#f87171;margin-top:8px;"></p>
  <p id="out" style="margin-top:12px;color:#7dd3fc;"></p>
</div>
<script>
const box = document.currentScript?.parentElement || document.getElementById('box-Ipv4RangeTool');
if (box) {
  const a = box.querySelector('#a'); const b = box.querySelector('#b'); const out = box.querySelector('#out'); const btn = box.querySelector('#run'); const err = box.querySelector('#err');
  const ip2int = s => s.split('.').reduce((x,o)=>x*256+parseInt(o),0)>>>0;
  const int2ip = n => [24,16,8,0].map(s=>(n>>s)&255).join('.');
  btn?.addEventListener('click', () => {
    const x = ip2int(a.value.trim()), y = ip2int(b.value.trim());
    if (x>y) { err.textContent='El inicio debe ser menor'; return; }
    let bits = 0; while (bits<32 && ((x & (1<<(31-bits))) === 0) && ((y>>(31-bits)) !== (x>>(31-bits)))) bits++;
    const mask = bits===0?0:(0xffffffff<<(32-bits))>>>0;
    if ((x & mask) !== x) { err.textContent='No cabe en una sola CIDR'; return; }
    out.textContent = int2ip(x & mask) + '/' + bits; err.textContent='';
  });
}
</script>
