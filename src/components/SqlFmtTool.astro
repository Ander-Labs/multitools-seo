---
const { } = Astro.props;
---
<div class="tool-box" id="box-SqlFmtTool">
  <label>SQL
    <textarea id="input" rows="6" placeholder="SELECT id FROM users WHERE active=1"></textarea>
  </label>
  <button id="run">Formatear</button>
  <label style="margin-top:12px; display:block;">Resultado
    <textarea id="output" rows="6" readonly></textarea>
  </label>
</div>
<script>
const box = document.currentScript?.parentElement || document.getElementById('box-SqlFmtTool');
if (box) {
  const input = box.querySelector('#input'); const output = box.querySelector('#output'); const btn = box.querySelector('#run');
  const KW = ['select','from','where','and','or','join','left join','right join','inner join','on','group by','order by','having','limit','insert into','values','update','set','delete','create table','alter table'];
  btn?.addEventListener('click', () => {
    let s = input.value.replace(/\s+/g,' ').trim();
    KW.sort((a,b)=>b.length-a.length).forEach(k => { s = s.replace(new RegExp('\\b'+k+'\\b','gi'), '\n'+k.toUpperCase()); });
    output.value = s.replace(/\n+/g,'\n').trim();
  });
}
</script>
