---
const { } = Astro.props;
---
<div class="tool-box">
  <label>JSON a formatear
    <textarea id="input" rows="8" placeholder="Pega tu JSON..."></textarea>
  </label>
  <button id="run">Formatear</button>
  <label style="margin-top:12px; display:block;">Resultado
    <textarea id="output" rows="8" readonly></textarea>
  </label>
</div>

<script>
  const box = document.currentScript?.parentElement;
  if (box) {
    const input = box.querySelector('#input') as HTMLTextAreaElement;
    const output = box.querySelector('#output') as HTMLTextAreaElement;
    const btn = box.querySelector('#run') as HTMLButtonElement;
    btn?.addEventListener('click', () => {
      try {
        const parsed = JSON.parse(input.value);
        output.value = JSON.stringify(parsed, null, 2);
      } catch (e) {
        output.value = 'Error: JSON inválido.';
      }
    });
  }
</script>
