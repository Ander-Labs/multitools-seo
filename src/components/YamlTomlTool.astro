---
const { } = Astro.props;
---
<div class="tool-box" id="box-YamlTomlTool">
  <label>YAML
    <textarea id="input" rows="8" placeholder="clave: valor"></textarea>
  </label>
  <button id="run">Convertir a TOML</button>
  <p id="err" style="color:#f87171;margin-top:8px;"></p>
  <label style="margin-top:12px; display:block;">TOML
    <textarea id="output" rows="8" readonly></textarea>
  </label>
</div>
<script>
import YAML from 'yaml'; import TOML from '@iarna/toml';
const box = document.currentScript?.parentElement || document.getElementById('box-YamlTomlTool');
if (box) {
  const input = box.querySelector('#input'); const output = box.querySelector('#output'); const btn = box.querySelector('#run'); const err = box.querySelector('#err');
  btn?.addEventListener('click', () => {
    try { const obj = YAML.parse(input.value); output.value = TOML.stringify(obj); err.textContent=''; }
    catch (e) { err.textContent = 'Error: ' + e.message; output.value=''; }
  });
}
</script>
